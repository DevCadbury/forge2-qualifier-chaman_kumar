# ============================================================
# Forge 2 Qualifier — Environment Variables
# Never commit real tokens or keys.
# ============================================================

# ──────────────────────────────────────────────────────────
# SLACK
# Create a Slack app at api.slack.com/apps
# ──────────────────────────────────────────────────────────

# Bot User OAuth Token (xoxb-...)
# OAuth & Permissions → Bot Token Scopes:
#   chat:write, channels:history, channels:read,
#   app_mentions:read, im:history, users:read
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token (xapp-...)
# Socket Mode → App-Level Tokens → scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Channel IDs — View channel details → copy the ID at the bottom
SLACK_CHANNEL_SPRINT_MAIN=C0XXXXXXXXX
SLACK_CHANNEL_AGENT_CODER=C0XXXXXXXXX
SLACK_CHANNEL_AGENT_LOG=C0XXXXXXXXX

# ──────────────────────────────────────────────────────────
# OLLAMA (local — free, no billing)
# Install: https://ollama.com
# Pull model: ollama pull rafw007/qwen35-claude-coder:4b
# ──────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=rafw007/qwen35-claude-coder:4b
OLLAMA_API_KEY=ollama     # Ollama ignores this value; any string works

# ──────────────────────────────────────────────────────────
# GROQ (free tier — used as fallback when Ollama is slow)
# Get key: console.groq.com
# ──────────────────────────────────────────────────────────

# GROQ_API_KEY=gsk_your-groq-key-here
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FALLBACK_MODEL=openai/gpt-oss-120b

# ──────────────────────────────────────────────────────────
# GOOGLE GEMINI (free tier — optional)
# Get key: aistudio.google.com
# ──────────────────────────────────────────────────────────

# GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────
# OPENCLAW
# Gateway token — set in openclaw.json under gateway.auth.token
# Generate any random string; used to authenticate local gateway calls
# ──────────────────────────────────────────────────────────

OPENCLAW_GATEWAY_TOKEN=your-random-gateway-token-here

# ──────────────────────────────────────────────────────────
# LARAVEL / BACKEND
# Copy backend/.env.example to backend/.env
# ──────────────────────────────────────────────────────────

APP_NAME="Kanban API"
APP_ENV=local
APP_KEY=                          # php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
# DB_DATABASE defaults to database/database.sqlite — no change needed locally

# CORS — must match your Vercel URL in production
FRONTEND_URL=http://localhost:5173

# Session / Cache / Queue
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail (use 'log' driver locally — writes to storage/logs/laravel.log)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="Kanban API"

# For real SMTP (Mailtrap free tier):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# MAIL_ENCRYPTION=tls

# ──────────────────────────────────────────────────────────
# FRONTEND (Vite / React)
# Set VITE_API_URL in Vercel dashboard — do NOT commit real URLs
# Locally this is not needed; App.jsx falls back to localhost:8000
# ──────────────────────────────────────────────────────────

# VITE_API_URL=https://your-render-service.onrender.com/api/v1

# ──────────────────────────────────────────────────────────
# PRODUCTION (Render backend)
# Set these in Render dashboard → Environment, not here
# ──────────────────────────────────────────────────────────

# APP_ENV=production
# APP_DEBUG=false
# DB_DATABASE=/var/data/database.sqlite
# LOG_CHANNEL=stderr
