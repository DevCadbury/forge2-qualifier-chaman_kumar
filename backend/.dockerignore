# Dependencies installed in the build stage
vendor/
node_modules/

# Runtime data — never bake into the image
.env
.env.*
!.env.example
database/database.sqlite
database/database.sqlite-shm
database/database.sqlite-wal

# Laravel caches — generated at container start by entrypoint.sh
bootstrap/cache/*.php
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
storage/logs/

# Dev / CI artefacts
.git/
.gitignore
docker-compose.yml
*.md
tests/
