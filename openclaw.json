{
  "agents": {
    "defaults": {
      "model": {
        "fallbacks": ["groq/llama-3.3-70b-versatile"],
        "primary": "ollama/rafw007/qwen35-claude-coder:4b"
      },
      "models": {
        "custom-127-0-0-1-11434/gpt-oss:20b": {},
        "google/gemini-2.5-flash": {},
        "groq/llama-3.3-70b-versatile": {},
        "groq/openai/gpt-oss-120b": {},
        "groq/openai/gpt-oss-20b": {},
        "groq/qwen/qwen3-32b": {},
        "ollama/rafw007/qwen35-claude-coder:4b": {}
      },
      "workspace": "C:\\Users\\<YOUR_USERNAME>\\.openclaw\\workspace"
    }
  },
  "auth": {
    "profiles": {
      "groq:default": {
        "mode": "api_key",
        "provider": "groq"
      },
      "ollama:default": {
        "provider": "ollama",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "slack": {
      "appToken": "SLACK_APP_TOKEN",
      "botToken": "SLACK_BOT_TOKEN",
      "capabilities": {
        "interactiveReplies": true
      },
      "channels": {
        "#agent-coder": { "enabled": true },
        "#agent-log":   { "enabled": true },
        "#sprint-main": { "enabled": true }
      },
      "enabled": true,
      "groupPolicy": "open"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "OPENCLAW_GATEWAY_TOKEN"
    },
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true
    },
    "mode": "local",
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    },
    "port": 18789,
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "custom-127-0-0-1-11434": {
        "api": "openai-completions",
        "apiKey": "ollama",
        "baseUrl": "http://127.0.0.1:11434/v1",
        "models": [
          {
            "contextWindow": 128000,
            "cost": { "cacheRead": 0, "cacheWrite": 0, "input": 0, "output": 0 },
            "id": "gpt-oss:20b",
            "input": ["text"],
            "maxTokens": 4096,
            "name": "gpt-oss:20b (Custom Provider)",
            "reasoning": false
          }
        ]
      },
      "ollama": {
        "api": "ollama",
        "apiKey": "OLLAMA_API_KEY",
        "baseUrl": "http://127.0.0.1:11434",
        "models": [
          {
            "id": "rafw007/qwen35-claude-coder:4b",
            "name": "rafw007/qwen35-claude-coder:4b",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 262144,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsUsageInStreaming": true
            }
          },
          {
            "id": "qwen3.5:2b",
            "name": "qwen3.5:2b",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 262144,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsUsageInStreaming": true
            }
          },
          {
            "id": "qwen2.5:latest",
            "name": "qwen2.5:latest",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsUsageInStreaming": true
            }
          },
          {
            "id": "gpt-oss:20b",
            "name": "gpt-oss:20b",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192,
            "compat": {
              "supportsTools": true,
              "supportsUsageInStreaming": true
            }
          }
        ]
      }
    }
  },
  "plugins": {
    "allow": ["ollama", "groq", "google", "slack"],
    "entries": {
      "google": { "enabled": true },
      "groq":   { "enabled": true },
      "slack":  { "enabled": true },
      "ollama": { "enabled": true }
    },
    "bundledDiscovery": "compat"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "alsoAllow": ["ollama_web_search", "ollama_web_fetch"],
    "web": {
      "fetch":  { "enabled": false },
      "search": { "enabled": false }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.6.10"
  }
}
